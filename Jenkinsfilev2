pipeline{
  agent any
  stages{
    stage('Build'){
      steps{
       echo"Installing dependencies..."
      }
    }
    stage('Test'){
      steps{
        echo"Running tests"
        sh 'python3 test.py'
      }
    }
    stage('Deploy'){
      echo'Deploying app'
      sh 'cp app.py /deploy/app.py'
    }
  }
  post{
    sucess{
      echo'Pipeline completed successfully!'
    }
    failure{
      echo'Pipeline failed! Check the log'
    }
  }
}
